FROM rust:1.86-bookworm AS builder
WORKDIR /build
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake pkg-config libcurl4-openssl-dev libsasl2-dev zlib1g-dev libssl-dev \
    && rm -rf /var/lib/apt/lists/*
COPY . .
RUN cargo build --release --bin sipora-edge

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release/sipora-edge /usr/local/bin/
EXPOSE 5061 443 5065 8080
ENTRYPOINT ["sipora-edge"]
