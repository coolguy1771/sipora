FROM rust:1.95-bookworm@sha256:6084021c0c650f9764a119f04973f18cb290cbd1cd97ccc837860b6e6e5c78c4 AS builder
WORKDIR /build
COPY . .
RUN cargo build --release --bin sipora-migrate

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release/sipora-migrate /usr/local/bin/
ENTRYPOINT ["sipora-migrate"]
